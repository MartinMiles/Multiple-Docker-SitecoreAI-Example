                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "site-data",
                "path": "/sitecore/content/Sites/xmc-one/Data",
                "scope": "itemAndDescendants",
                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "site-dictionary",
                "path": "/sitecore/content/Sites/xmc-one/Dictionary",
