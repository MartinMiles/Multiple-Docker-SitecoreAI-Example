                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "site-home",
                "path": "/sitecore/content/Sites/xmc-one/Home",
                "scope": "itemAndDescendants",
                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "site-presentation",
                "path": "/sitecore/content/Sites/xmc-one/Presentation",
                "scope": "itemAndDescendants",
                "allowedPushOperations": "CreateAndUpdate"
            }
        ]
