{
    "$schema": "../../.sitecore/schemas/ModuleFile.schema.json",
    "namespace": "xmc-one-site",
    "items": {
        "path": "xmc-one-site",
        "includes": [
            {
                "name": "site-collection",
                "path": "/sitecore/content/Sites",
                "scope": "singleItem",
                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "site-root",
                "path": "/sitecore/content/Sites/xmc-one",
                "scope": "singleItem",
                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "site-settings",
                "path": "/sitecore/content/Sites/xmc-one/Settings",
