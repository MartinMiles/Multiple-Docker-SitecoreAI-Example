# Vanilla starter kit source (used for cloning new codebases)
xmcloud-starter-js/

# Generated TLS certificates (regenerated by setup-multi.ps1)
shared-traefik/traefik/certs/*.pem
shared-traefik/traefik/certs/mkcert.exe

# Docker persistent data volumes
**/mssql-data/
**/solr-data/
**/docker/data/

# Node.js
**/node_modules/
**/.next*/

# .env files contain instance-specific secrets (passwords, API keys, auth tokens)
**/local-containers/.env

# Sitecore CLI auth tokens
**/.sitecore/user.json
**/.sitecore/package-cache/
**/.scindex

# Windows
Thumbs.db
Desktop.ini

# IDE and tools
.vs/
.vscode/
.idea/
*.swp
*.swo
.claude/settings.local.json

# Build artifacts
**/[Bb]in/
**/[Oo]bj/
*.exe
*.pdb
*.cache
